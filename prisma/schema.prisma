generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  USER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizType {
  PUBLIC
  PRIVATE
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role     @default(USER)
  isGroupLeader Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  attempts  QuizAttempt[]
  quizLinks QuizLink[]
}

model Quiz {
  id          String     @id @default(cuid())
  title       String
  description String?
  difficulty  Difficulty @default(MEDIUM)
  durationMin Int        @default(20)
  type        QuizType   @default(PRIVATE)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions Question[]
  attempts  QuizAttempt[]
  quizLinks QuizLink[]
}

model Question {
  id            String     @id @default(cuid())
  text          String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  difficulty    Difficulty @default(MEDIUM)
  order         Int        @default(0)
  quizId        String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  quizId      String
  answers     String    @default("{}")
  score       Int?
  totalPoints Int?
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  isComplete  Boolean   @default(false)

  user User @relation(fields: [userId], references: [id])
  quiz Quiz @relation(fields: [quizId], references: [id])

  @@unique([userId, quizId])
}

model QuizLink {
  id        String    @id @default(cuid())
  userId    String?
  quizId    String
  token     String    @unique
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])
  quiz Quiz  @relation(fields: [quizId], references: [id])
}
